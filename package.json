    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:e2e": "playwright test",
    "test:coverage": "vitest run --coverage",
    "test:ci": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm build && pnpm test:e2e"
  },
